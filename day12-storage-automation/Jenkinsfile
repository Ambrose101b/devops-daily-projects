pipeline {
    agent any 
    
    stages {
        stage('Sync Code') {
            steps {
                echo '📥 Pulling fresh code from GitHub...'
                checkout scm 
            }
        }
        
        stage('Build Image') {
            steps {
                dir('day12-storage-automation') {
                    echo '🔨 Building the storage-tool Docker image...'
                    sh 'docker build -t storage-tool:latest .'
                }
            }
        }
        
        stage('Run Health Check') {
            steps {
                echo '📊 Running the Python Disk Check (Default CMD)...'
                // This runs the default CMD (monitor_disk.py)
                sh 'docker run --rm -v /tmp:/tmp storage-tool:latest'
                
                echo '🧹 Running the Bash Log Cleanup (Override CMD)...'
                // By adding 'bash cleanup.sh' at the end, we OVERRIDE the Python script and run the Bash script instead!
                sh 'docker run --rm -v /tmp:/tmp storage-tool:latest bash cleanup.sh'
            }
        }
    }
    
    post {
        success {
            echo '✅ SUCCESS: Day 12 Automation Complete. Server is healthy!'
        }
        failure {
            echo '❌ FAILURE: Check disk space or script syntax.'
        }
    }
}
